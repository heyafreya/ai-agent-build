# LLM Provider
# Options: anthropic, openai, gemini, groq, ollama, openrouter
LLM_PROVIDER=gemini
# Gemini free tier — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Or uncomment for other providers:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# Agent configuration
AGENT_MODEL=gemini/gemini-2.0-flash-exp
# AGENT_MODEL=groq/llama3-70b-8192
# AGENT_MODEL=ollama/llama3.2
